manifest {
    name = 'SynTerra'
    description = 'Synteny-guided gene finding across genomes using iterative search'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '!>=22.10.1'
}

params {
    // Input - Query (one of these required)
    gene = null           // Path to query gene FASTA (DNA or protein)
    query_id = null       // UniProt ID (e.g., P01501) - will fetch automatically
    
    // Mode selection
    mode = 'easy'         // 'easy' or 'pro'
    
    // Easy mode - just species name, we fetch everything from NCBI
    home_species = null   // e.g., "Apis mellifera" - fetches reference genome + related species
    max_genomes = 10      // Number of related genomes to download
    target_species = null  // Comma-separated species names (e.g., "Ooceraea biroi,Harpegnathos saltator")
    
    // Pro mode - provide your own files  
    home_genome = null    // Path to home genome FASTA
    home_gff = null       // Path to home genome GFF (optional)
    target_genomes = null // Glob pattern for target genomes (e.g., "genomes/*.fna")
    
    // Synteny parameters
    n_flanking_genes = 10
    prefer_large_genes = true
    min_flanking_size = 500
    exon_level_search = true  // Search at exon level for better divergent gene detection
    
    // Search parameters
    cluster_distance = 50000
    min_synteny_score = 0.6  // 60% flanking gene conservation required
    min_hit_identity = 40
    min_hit_length = 100
    search_evalue = 1e-5
    max_intron = 20000
    
    // Smith-Waterman search (for GOI in regions)
    enable_smith_waterman = true  // Use rigorous SW alignment for GOI
    sw_method = "auto"  // auto, parasail, or ssearch36
    sw_min_score = 50
    sw_min_identity = 20.0
    sw_timeout_seconds = 300
    
    // Augmentation / adaptive search
    region_padding = 150000
    padding_min = 50000
    padding_max = 200000
    aug_relaxed_evalue_mult = 1000
    aug_relaxed_evalue_cap = 10.0
    aug_relaxed_parse_evalue_mult = 10
    aug_relaxed_identity_factor = 0.6
    aug_relaxed_identity_min = 25.0
    aug_relaxed_length_div = 2
    aug_relaxed_length_min = 15
    aug_dedup_bin_bp = 100
    
    // Sensitivity
    mmseqs_sensitivity = 8.5
    min_gene_identity = 30

    // Unused (reserved for future wiring)
    augustus_species = 'honeybee1'  // Change based on your organism
    expand_db_threshold = 1e-10
    diamond_sensitivity = "very-sensitive"
    enable_splice_variants = true
    enable_frameshifts = true
    mutation_rate = 0.05
    num_mutant_variants = 10

    // Annotation windows and filters
    gff_search_window = 100000
    gap_search_window = 50000
    gap_min_size = 10
    gap_evalue = 10
    gap_min_identity = 25.0
    gap_min_alnlen = 10
    gap_max_hits = 5
    min_exon_query_cov = 0.25
    min_exon_alnlen = 30

    // Prodigal prediction windows
    pred_flank_window = 50000
    pred_keep_pct = 0.10
    prodigal_full_genome_fallback = false

    // Synteny scoring weights
    synteny_weight_base = 0.4
    synteny_weight_consistency = 0.3
    synteny_weight_strand = 0.3
    
    // Output
    outdir = 'results'
    
    // Advanced options
    keep_intermediate = false  // Set to true for debugging
    max_retries = 3
}

// Profiles
profiles {
    standard {
        process.executor = 'local'
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }
    
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = "${projectDir}/environment.yml"
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled = false
        singularity.enabled = false
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
        conda.enabled = false
    }
    
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'  // Change to your cluster's partition
        process.clusterOptions = '--account=your_account'  // Optional: billing account
        // Uncomment and adjust for your cluster:
        // process.queue = 'gpu'  // or 'long', 'batch', etc.
        // executor.queueSize = 50  // Max jobs to submit at once
        // executor.submitRateLimit = '10/1min'  // Rate limit submissions
    }
    
    // Combined profiles for common HPC setups
    hpc_singularity {
        process.executor = 'slurm'
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${HOME}/.singularity/cache"
        docker.enabled = false
        conda.enabled = false
    }
    
    hpc_conda {
        process.executor = 'slurm'
        conda.enabled = true
        conda.useMamba = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = "${projectDir}/environment.yml"
    }
    
    test {
        includeConfig 'conf/test.config'
    }
    test_melettin {
        process.executor = 'local'
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
        includeConfig 'conf/test_melettin.config'
    }
    test_tetramorium {
        includeConfig 'conf/test_tetramorium.config'
    }
}

// Process-specific resource requirements
process {
    // Default
    cpus = 1
    memory = '2 GB'
    time = '1h'
    
    errorStrategy = { task.exitStatus in [143,137,104,134,139,140] ? 'retry' : 'finish' }
    maxRetries = 2
    
    withName: 'ITERATIVE_SEARCH' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
    }
    withName: 'COMPUTE_TREE' {
        cpus = 2
        memory = '4 GB'
    }
}

// Container definitions (used when docker or singularity profile is active)
// Single container with all tools - simpler than per-process containers
process {
    // BioContainers mulled container with mmseqs2, mafft, fasttree, prodigal, miniprot, bedtools
    // For custom container, build with Dockerfile and push to registry
    container = 'quay.io/biocontainers/mulled-v2-949aaaddebd054dc6bded102520daff6f0f93ce6:aa5e66741ab99c00e7f30adb3c6e9fee22c5f5f5-0'
}

// Conda settings
conda {
    createTimeout = '1 h'
    useMamba = true  // Use mamba for faster env creation (if available)
}
