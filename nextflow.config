manifest {
    name = 'SynVoy'
    description = 'Synteny-guided gene finding across genomes using iterative search'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '!>=22.10.1'
}

/*
 * Host resource detection (used by docker_max profile).
 * Falls back conservatively if detection fails.
 */
def hostCpuCount = {
    try {
        return Math.max(1, Runtime.runtime.availableProcessors() as Integer)
    } catch (Exception ignored) {
        return 2
    }
}()

def hostMemGb = {
    try {
        def meminfo = new File('/proc/meminfo')
        if (meminfo.exists()) {
            def line = meminfo.readLines().find { it.startsWith('MemTotal:') }
            if (line) {
                def kb = (line.split(':')[1].trim().split(/\s+/)[0]) as Long
                return Math.max(2, (int)Math.floor(kb / (1024d * 1024d)))
            }
        }
    } catch (Exception ignored) {
    }
    return 8
}()

def dockerMaxMemGb = Math.max(2, hostMemGb - 1)
def iterativeMaxMemGb = Math.max(2, hostMemGb - 2)
def mmseqsSplitMaxGb = Math.max(2, (int)Math.floor(iterativeMaxMemGb * 0.70d))

ansi {
    enabled = true
}

params {
    // Input - Query
    query = null          // Path to local query FASTA file (Pro Mode or Easy Mode with file input)
    query_id = null       // UniProt/NCBI Accession ID (Easy Mode)
    query_seq = null      // Inline protein sequence or FASTA text (Easy Mode)
    
    // Mode selection
    mode = 'easy'         // 'easy' or 'pro'
    
    // Easy mode
    home_species = null   // Optional. Easy-mode home species name override. Automatically detected otherwise.
    max_genomes = 0       // 0 = Auto-detect based on taxonomy (3 per level). Or specify count.
    target_species = null // Comma-separated species names (e.g., "Ooceraea biroi,Harpegnathos saltator")
    assembly_ranking = 'hybrid'  // easy-mode selection: hybrid, counts, nstats
    bad_quality_policy = 'drop'  // easy-mode low-quality handling: ask, drop, keep
    bad_quality_timeout = 300    // seconds to wait for answer when policy=ask
    bad_max_contigs = 500000     // above this contig count => low quality
    bad_max_scaffolds = 500000    // above this scaffold count => low quality
    bad_min_n50 = 5000            // below this best-N50 => low quality
    qc_fail_policy = 'drop'      // downstream target filtering after QC: drop or keep
    
    // Pro mode  
    home_genome = null    // Path to home genome FASTA
    home_gff = null       // Path to home genome GFF (optional)
    target_genomes = null // Glob, comma-separated paths, or list (e.g., "genomes/*.fna" or "a.fna,b.fna")
    
    // Synteny parameters
    n_flanking_genes = 10        // Non-GOI-similar flanking genes to select per side
    prefer_large_genes = true
    min_flanking_size = 500
    exon_level_search = true     // Search at exon level for better divergent gene detection
    // Flanking gene quality filter: exclude flanking candidates with k-mer similarity
    // above this threshold to the GOI (catches LY6/3FTx family members, GPI-anchored
    // proteins, etc. that are useless as cross-species synteny anchors).
    // Set to 100 to disable (accept all flanking genes regardless of GOI similarity).
    max_flanking_goi_similarity = 35.0
    // Max distance (bp) from GOI center to walk for flanking genes.
    // 0 = unlimited (legacy). Set e.g. 500000 to prevent reaching into gene deserts
    // when the GOI neighbours a tandem array that fills one side (e.g. Y-e3 + MRJP cluster).
    max_flanking_distance = 0
    // When true, GOI-similar genes within expand_goi_similar_distance bp of the GOI are
    // emitted as additional GOI queries (GOI_NEIGHBOR_ prefix). They are searched in all
    // target genomes and included in IQ-TREE.
    //
    // OFF BY DEFAULT (was previously on, reverted 2026-04-25): for paralog-rich gene
    // families like LY6 the NEIGHBOR queries flood the per-target m8 with paralog
    // matches, causing the synteny-anchor signal to flatten and the true ortholog
    // scaffold to drop out of the top-`adaptive_max_regions`. LY6 baseline went from
    // 8/9 scaffold recall (off) to 0/9 (on). It can still help in narrow cases
    // (single-copy gene with known nearby tandem duplicates that are the targets
    // themselves, e.g. some venom peptides) — opt in explicitly with
    // `--expand_goi_similar true`. See docs/PARAMETERS.md for trade-offs.
    expand_goi_similar = false
    expand_goi_similar_distance = 300000
    
    // Search parameters
    cluster_distance = 150000
    min_synteny_score = 0.6  // 60% flanking gene conservation required
    min_hit_identity = 10
    min_hit_length = 10
    min_query_length = 30  // reject queries shorter than this (aa); set to 0 to disable
    search_evalue = 0.01
    max_intron = 20000
    
    // Smith-Waterman search (for GOI in regions)
    enable_smith_waterman = true  // Use rigorous SW alignment for GOI
    sw_method = "auto"  // auto, parasail, or ssearch36
    sw_min_score = 20
    sw_min_identity = 10.0
    sw_timeout_seconds = 300
    
    // Augmentation / adaptive search
    region_padding = 150000
    padding_min = 50000
    padding_max = 200000
    aug_relaxed_evalue_mult = 1000
    aug_relaxed_evalue_cap = 10.0
    aug_relaxed_parse_evalue_mult = 10
    aug_relaxed_identity_factor = 0.6
    aug_relaxed_identity_min = 15.0
    aug_relaxed_length_div = 2
    aug_relaxed_length_min = 15
    aug_dedup_bin_bp = 100
    max_blocks_per_genome = 80
    min_block_genes = 2
    max_consecutive_empty_blocks = 25
    
    // Sensitivity
    mmseqs_sensitivity = 9.5
    mmseqs_split_memory_limit = '8G'
    mmseqs_verbosity = 1
    min_gene_identity = 30

    // Iterative search resource guards (local-safe defaults)
    iterative_search_cpus = 2
    iterative_search_memory = '10 GB'
    iterative_search_max_forks = 1
    iterative_quiet_subtools = true

    // Classification thresholds (GOI confidence / model status)
    classify_high_min_identity = 50.0     // lowered from 60 for cross-vertebrate orthologs
    classify_medium_min_identity = 35.0   // lowered from 45 for divergent orthologs
    classify_tandem_min_identity = 40.0
    classify_fragment_max_qcov = 0.4
    classify_complete_min_qcov = 0.7

    // Strict family-consistency gate (Change A). When true, fallback/rescued_exon/
    // raw_hit GOI calls whose TargetGene/TargetProduct does not match the family
    // tokens are downgraded to LOW/ambiguous. Tokens auto-derived from the query
    // FASTA header (GN=...) unless overridden.
    strict_goi_family = false
    goi_family_tokens = ''
    locate_gene_cpus = 1
    locate_gene_memory = '3 GB'

    // PLM (Protein Language Model) embedding search
    // Uses ProtT5-XL to detect remote homologs via embedding similarity.
    // Requires: pip install torch transformers sentencepiece  (optional)
    enable_plm_search = false          // Enable ProtT5 embedding search
    plm_device = 'cpu'                 // 'cpu' or 'cuda' (GPU accelerated)
    plm_similarity_threshold = 0.5     // Min cosine similarity for ORF discovery
    plm_medium_threshold = 0.7         // Embedding sim ≥ this → can boost LOW → MEDIUM
    plm_high_threshold = 0.85          // Embedding sim ≥ this → can boost MEDIUM → HIGH

    // Structural search (ESMFold + Foldseek)
    // Predicts 3D structures for candidate ORFs and compares against GOI
    // via Foldseek 3Di structural alphabet. Catches divergent orthologs
    // where even PLM embeddings fail (structure diverges ~10x slower than sequence).
    // Requires: pip install torch transformers; conda install -c bioconda foldseek
    enable_structural_search = false       // Enable ESMFold + Foldseek search
    structural_device = 'cpu'              // 'cpu' or 'cuda' (GPU strongly recommended)
    structural_tm_threshold = 0.3          // Min TM-score for Foldseek ORF discovery
    structural_medium_threshold = 0.5      // TM-score ≥ this → can boost LOW → MEDIUM
    structural_high_threshold = 0.7        // TM-score ≥ this → can boost MEDIUM → HIGH
    structural_max_length = 700            // Max residues for ESMFold (VRAM safety)

    // Unused (reserved for future wiring)
    expand_db_threshold = 1e-10
    diamond_sensitivity = "very-sensitive"
    enable_splice_variants = true
    enable_frameshifts = true
    mutation_rate = 0.05
    num_mutant_variants = 10

    // Annotation windows and filters
    gff_search_window = 100000
    gap_search_window = 50000
    gap_min_size = 10
    gap_evalue = 10
    gap_min_identity = 15.0
    gap_min_alnlen = 10
    gap_max_hits = 5
    min_exon_query_cov = 0.25
    min_exon_alnlen = 30

    // Gene prediction
    // Augustus (eukaryotes) or Prodigal (prokaryotes). Default: auto (prefer Augustus).
    // Prodigal cannot predict intron-containing genes — use Augustus for eukaryotes!
    gene_predictor = 'auto'           // 'auto', 'augustus', or 'prodigal'
    augustus_species = 'fly'           // Augustus species model (e.g. fly, human, honeybee1)
    pred_flank_window = 50000
    pred_keep_pct = 0.10
    prodigal_full_genome_fallback = false

    // Synteny scoring weights
    synteny_weight_base = 0.4
    synteny_weight_consistency = 0.3
    synteny_weight_strand = 0.3
    synteny_goi_overlap_bonus = 0.15
    max_regions = 0                  // 0 = adaptive (emit all above threshold, cap 6)
    // Adaptive region selection (only used when max_regions=0). Defaults match
    // previous hard-coded behavior so non-strict runs are unaffected.
    adaptive_score_floor_frac = 0.30
    adaptive_score_floor_abs  = 0.03
    adaptive_max_regions      = 6
    adaptive_unique_gene_floor = 3
    
    // Output and Plotting
    outdir = 'results'
    plot_width = 1500
    gap_threshold = 50000
    gap_visual_size = 20000
    flank_fallback_bp = 1000000
    scale_bar_len = 10000
    hide_goi_absent_tracks = true

    docker_container = 'synvoy-local:latest'

    // LLM Parameter Estimation (Gemma 4 via Ollama / Google Cloud)
    // When enabled, SynVoy analyzes the query gene, home species, and target
    // genomes to automatically estimate optimal search parameters.
    // Falls back to rule-based heuristics when no LLM backend is available.
    auto_params = true                     // Enable automatic parameter estimation (default: ON)
    llm_model = 'auto'                     // Ollama model: 'auto', 'gemma4:e4b', 'gemma4:26b', 'gemma4:31b'
    ollama_url = 'http://localhost:11434'   // Ollama server URL
    ollama_timeout = 480                   // Ollama request timeout in seconds (CPU inference needs ~4min)
    // Google Cloud API key: set via --google_api_key or GOOGLE_API_KEY env var
    google_api_key = ''
    // Multi-profile mode: run with multiple parameter sets and pick the best
    multi_profile = true                   // Enable multi-profile mode (auto-disabled when too expensive)
    multi_profile_max_jobs = 30            // Max total jobs (loci × targets × profiles) for multi-profile
    
    // Advanced options
    keep_intermediate = false  // Set to true for debugging
    max_retries = 3
}

// Ensure environment variables are passed to executors
env {
    GOOGLE_API_KEY = params.google_api_key ?: (System.getenv('GOOGLE_API_KEY') ?: '')
}

// Profiles
profiles {
    standard {
        process.executor = 'local'
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }
    
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = "${projectDir}/environment.yml"
    }

    // Conservative local profile for laptops/workstations that may otherwise freeze
    // under heavy genome downloads + MMseqs/tBLASTN load.
    laptop_safe {
        process.executor = 'local'
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = "${projectDir}/environment.yml"

        params.iterative_search_cpus = 1
        params.iterative_search_memory = '12 GB'
        params.iterative_search_max_forks = 1
        params.locate_gene_cpus = 1
        params.locate_gene_memory = '2 GB'
        params.mmseqs_split_memory_limit = '8G'
        params.mmseqs_verbosity = 0
        params.iterative_quiet_subtools = true

        process {
            maxForks = 1
        }
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled = false
        singularity.enabled = false
    }

    // Host-maximizing Docker profile (single-job saturation).
    // Uses almost all local CPU/RAM while keeping a tiny safety margin.
    docker_max {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled = false
        singularity.enabled = false

        params.iterative_search_cpus = hostCpuCount
        params.iterative_search_memory = "${iterativeMaxMemGb} GB"
        params.iterative_search_max_forks = 1
        params.locate_gene_cpus = hostCpuCount
        params.locate_gene_memory = "${dockerMaxMemGb} GB"
        params.mmseqs_split_memory_limit = "${mmseqsSplitMaxGb}G"

        process {
            cpus = hostCpuCount
            memory = "${dockerMaxMemGb} GB"
            maxForks = 1

            withName: 'ITERATIVE_SEARCH' {
                cpus = hostCpuCount
                memory = "${iterativeMaxMemGb} GB"
                maxForks = 1
            }
            withName: 'LOCATE_GENE' {
                cpus = hostCpuCount
                memory = "${dockerMaxMemGb} GB"
            }
            withName: 'COMPUTE_TREE' {
                cpus = hostCpuCount
                memory = "${dockerMaxMemGb} GB"
            }
        }
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
        conda.enabled = false
    }
    
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'  // Change to your cluster's partition
        process.clusterOptions = '--account=your_account'  // Optional: billing account
        // Uncomment and adjust for your cluster:
        // process.queue = 'gpu'  // or 'long', 'batch', etc.
        // executor.queueSize = 50  // Max jobs to submit at once
        // executor.submitRateLimit = '10/1min'  // Rate limit submissions
    }
    
    // Combined profiles for common HPC setups
    hpc_singularity {
        process.executor = 'slurm'
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${HOME}/.singularity/cache"
        docker.enabled = false
        conda.enabled = false
    }
    
    hpc_conda {
        process.executor = 'slurm'
        conda.enabled = true
        conda.useMamba = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = "${projectDir}/environment.yml"
    }
    
    test {
        includeConfig 'conf/test.config'
    }
    test_melettin {
        process.executor = 'local'
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
        includeConfig 'conf/test_melettin.config'
    }
    test_tetramorium {
        includeConfig 'conf/test_tetramorium.config'
    }
}

// Process-specific resource requirements
process {
    // Default
    cpus = 1
    memory = '2 GB'
    time = '1h'
    
    errorStrategy = { task.exitStatus in [143,137,104,134,139,140] ? 'retry' : 'terminate' }
    maxRetries = 2
    
    withName: 'ITERATIVE_SEARCH' {
        cpus = params.iterative_search_cpus as Integer
        memory = params.iterative_search_memory
        maxForks = params.iterative_search_max_forks as Integer
        time = '48h'
        queue = 'gpu-node'
        clusterOptions = '--gres=gpu:1'
    }
    withName: 'LOCATE_GENE' {
        cpus = params.locate_gene_cpus as Integer
        memory = params.locate_gene_memory
        time = '48h'
    }
    withName: 'PHYLO_SORT' {
        memory = '8 GB'
    }
    withName: 'FETCH_RELATED_GENOMES' {
        time = '3h'
        maxRetries = 3
    }
    withName: 'FETCH_HOME_GENOME' {
        time = '3h'
        maxRetries = 3
    }
    withName: 'COMPUTE_TREE' {
        cpus = 2
        memory = '4 GB'
        time = '4h'
    }
    withName: 'PREPARE_HOME_PROTEOME' {
        time = '3h'
    }
    withName: 'ANNOTATE_GOI' {
        time = '3h'
    }
    withName: 'EXTRACT_FLANKING' {
        time = '3h'
    }
}

// Container definitions (used when docker or singularity profile is active)
// Single container with all tools - simpler than per-process containers
process {
    // Build the bundled Dockerfile as `synvoy-local:latest`, or override with:
    //   --docker_container your/image:tag
    container = params.docker_container
    // Ensure workspace scripts override packaged container scripts.
    beforeScript = "export PATH=${projectDir}/bin:\\$PATH"
}

// Conda settings
conda {
    createTimeout = '1 h'
    useMamba = true  // Use mamba for faster env creation (if available)
}
