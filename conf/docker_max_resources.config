/*
 * Host resource detection for docker_max profile.
 * Separated into its own file for Nextflow 26.x strict syntax compatibility.
 *
 * Detects available CPUs and RAM, then sets process resources to use
 * almost all host capacity with a small safety margin.
 */

// --- Detect host CPUs ---
params._host_cpus = Runtime.runtime.availableProcessors()
if (params._host_cpus < 1)
    params._host_cpus = 2

// --- Detect host memory (GB) from /proc/meminfo ---
params._host_mem_gb = 8
def _meminfo = new File('/proc/meminfo')
if (_meminfo.exists()) {
    def _lines = _meminfo.readLines()
    def _memline = _lines.find { it.startsWith('MemTotal:') }
    if (_memline) {
        def _kb = (_memline.split(':')[1].trim().split(/\s+/)[0]) as Long
        def _gb = (_kb / 1048576) as int    // kB -> GB  (1048576 = 1024*1024)
        params._host_mem_gb = _gb > 2 ? _gb : 2
    }
}

// --- Derived memory values ---
params._docker_max_mem_gb = params._host_mem_gb > 3 ? params._host_mem_gb - 1 : 2
params._iterative_max_mem_gb = params._host_mem_gb > 4 ? params._host_mem_gb - 2 : 2
params._mmseqs_split_max_gb = (params._iterative_max_mem_gb * 0.70) as int
if (params._mmseqs_split_max_gb < 2)
    params._mmseqs_split_max_gb = 2

// --- Apply to user-facing params ---
params.iterative_search_cpus = params._host_cpus
params.iterative_search_memory = "${params._iterative_max_mem_gb} GB"
params.iterative_search_max_forks = 1
params.locate_gene_cpus = params._host_cpus
params.locate_gene_memory = "${params._docker_max_mem_gb} GB"
params.mmseqs_split_memory_limit = "${params._mmseqs_split_max_gb}G"

// --- Process resource assignments ---
process {
    cpus = params._host_cpus
    memory = "${params._docker_max_mem_gb} GB"
    maxForks = 1

    withName: 'ITERATIVE_SEARCH' {
        cpus = params._host_cpus
        memory = "${params._iterative_max_mem_gb} GB"
        maxForks = 1
    }
    withName: 'LOCATE_GENE' {
        cpus = params._host_cpus
        memory = "${params._docker_max_mem_gb} GB"
    }
    withName: 'COMPUTE_TREE' {
        cpus = params._host_cpus
        memory = "${params._docker_max_mem_gb} GB"
    }
}
