/*
 * -------------------------------------------------
 *  Nextflow config file for running tests on Tetramorium
 * -------------------------------------------------
 */

params {
    // Input data
    // Query Gene (Protein sequence provided)
    gene = 'test_data/tetramorium_query.fasta'
    
    // Home Genome: Tetramorium bicarinatum
    home_genome = 'test_data/genomes/Tetramorium_bicarinatum/ncbi_dataset/data/GCA_928718305.1/GCA_928718305.1_Tetramorium_bicarinatum_1.0_genomic.fna'
    
    // Note: No GFF provided for Home Genome, so pipeline should predict genes or use existing logic if any.
    // Actually, LOCATE_GENE runs tblastn to find the gene location, 
    // and EXTRACT_FLANKING requires a GFF or runs prediction.
    home_gff = null 

    // Target Genomes
    target_genomes = [
        'test_data/genomes/apis_mellifera/ncbi_dataset/data/GCF_003254395.2/GCF_003254395.2_Amel_HAv3.1_genomic.fna',
        'test_data/genomes/bombus_terestris/ncbi_dataset/data/GCA_910591885.2/GCA_910591885.2_iyBomTerr1.2_genomic.fna',
        'test_data/genomes/pogomomyrmex_californicus/ncbi_dataset/data/GCA_050084945.1/GCA_050084945.1_Pcal3.1_genomic.fna',
        'test_data/genomes/vespa_velutina/ncbi_dataset/data/GCA_912470025.1/GCA_912470025.1_iVesVel2.1_genomic.fna'
    ]
    
    // Output directory
    outdir = 'results/test_tetramorium'
    mode = 'pro'
    
    min_synteny_score = 0.01 // Lowered again to capture regions even if home genome has multiple hits diluting the score
    n_flanking_genes = 10
    mmseqs_sensitivity = 8.5 // relaxed for now
}
