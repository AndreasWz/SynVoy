// Strict-orthology profile for TP53-family runs.
// Use: nextflow run main.nf -c conf/tp53_strict.config ...
// Or add `-profile tp53_strict` after wiring in nextflow.config.

params {
    // Enable family-consistency gate
    strict_goi_family = true
    // Accept all three vertebrate p53 paralogs + mouse Trp variants
    goi_family_tokens = 'TP53,TP63,TP73,TRP53,TRP63,TRP73,P53,P63,P73'

    // Tighter identity thresholds for precision-focused runs
    classify_high_min_identity    = 55.0
    classify_medium_min_identity  = 40.0
    classify_tandem_min_identity  = 50.0
    classify_fragment_max_qcov    = 0.35
    classify_complete_min_qcov    = 0.75

    // Tighter adaptive region selection (prevents the LOW-score region tail
    // seen in TP53 runs where 5/6 genomes emitted 6 noise regions at S0.15–0.20)
    adaptive_score_floor_frac   = 0.45
    adaptive_score_floor_abs    = 0.08
    adaptive_max_regions        = 4
    adaptive_unique_gene_floor  = 3

    // Disable LLM/multi-profile for reproducibility
    auto_params      = false
    multi_profile    = false
}
