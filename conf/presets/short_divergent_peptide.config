// SynVoy preset: short divergent peptide (< ~100 aa)
//
// For: short secreted peptides, micro-exon toxins, antimicrobial peptides,
// small venom components. Examples: melittin (70 aa), defensins, mastoparan,
// small 3FTx toxins (snake venom).
//
// Why this preset: short proteins inherently produce lower-scoring alignments
// (less signal in 26 aa than in 260 aa). Default identity and coverage
// thresholds rule out genuine orthologs. Default `min_query_length=30` rejects
// genuinely short queries. Single-copy assumption — peptide families are
// typically not tandem arrays (most are tightly regulated single copies).
//
// Validated on: melittin benchmark (results/melettin_benchmark/) — recovers
// 11/12 GR2-family orthologs across 200 Myr of Hymenoptera.
//
// Use:   nextflow run main.nf -profile standard,preset_short_peptide ...
//   or:  nextflow run main.nf -c conf/presets/short_divergent_peptide.config ...

params {
    // Lower SW and hit-identity thresholds — short proteins need them.
    sw_min_score      = 10
    sw_min_identity   = 8.0
    min_hit_identity  = 8
    min_hit_length    = 8
    min_query_length  = 20

    // Coverage thresholds tuned for ~70 aa proteins: a single missed exon
    // (~30 aa) drops a melittin hit below the default qcov=0.7 "complete" bar.
    classify_complete_min_qcov   = 0.5
    classify_fragment_max_qcov   = 0.3
    classify_high_min_identity   = 40.0
    classify_medium_min_identity = 25.0

    // Single-copy assumption.
    expand_goi_similar = false
    // Family tokens are rarely consistent for short peptides across taxa
    // (e.g. melittin → bombolitin in Bombus). Leave family gate off.
    strict_goi_family  = false
}
