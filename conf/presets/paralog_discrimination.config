// SynVoy preset: paralog discrimination (close paralog family)
//
// For: gene families with a small number of close paralogs that need to be
// distinguished, NOT lumped together. Examples: TP53/TP63/TP73, SOX1-21,
// HOX clusters, paired ZNFs. Different from `preset_tandem_family` because
// the family has 2–10 members (not dozens of tandem copies) and you want
// SynVoy to call each paralog at its own syntenic locus.
//
// Why this preset: tight family-identity gate combined with tight adaptive
// region selection prevents the LOW-score region tail (seen in TP53 runs
// where 5/6 genomes emitted 6 noise regions at synteny score 0.15–0.20).
//
// IMPORTANT: set `--goi_family_tokens` to your full paralog list.
//   For TP53: --goi_family_tokens 'TP53,TP63,TP73,TRP53,TRP63,TRP73,P53,P63,P73'
//   For HOXA: --goi_family_tokens 'HOXA1,HOXA2,HOXA3,...'
// If the GOI is a UniProt accession with a clean header, the default
// auto-derived token may suffice — but multi-paralog runs usually need
// the explicit override.
//
// Validated on: TP53 run (results/tp53_15042026_with_fixes/) — clean
// TP53/TP63/TP73 paralog calls at their respective syntenic loci.
//
// Use:   nextflow run main.nf -profile standard,preset_paralog_discrimination \
//          --goi_family_tokens 'TP53,TP63,TP73' ...
//   or:  nextflow run main.nf -c conf/presets/paralog_discrimination.config \
//          --goi_family_tokens 'TP53,TP63,TP73' ...

params {
    strict_goi_family = true
    // Default tokens for TP53 family — override for other paralog groups.
    goi_family_tokens = 'TP53,TP63,TP73,TRP53,TRP63,TRP73,P53,P63,P73'

    // Tighter classification bars.
    classify_high_min_identity   = 55.0
    classify_medium_min_identity = 40.0
    classify_tandem_min_identity = 50.0
    classify_fragment_max_qcov   = 0.35
    classify_complete_min_qcov   = 0.75

    // Tighter adaptive region selection — kills the LOW-score noise tail.
    adaptive_score_floor_frac  = 0.45
    adaptive_score_floor_abs   = 0.08
    adaptive_max_regions       = 4
    adaptive_unique_gene_floor = 3

    // Reproducibility: no LLM, no multi-profile.
    auto_params   = false
    multi_profile = false
}
