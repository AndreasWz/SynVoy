// SynVoy preset: single-copy conserved gene
//
// For: housekeeping genes, well-conserved single-copy orthologs across the
// queried taxa. Examples: ACTB, EF1A, ribosomal proteins, conserved
// transcription factors. The default SynVoy parameters are tuned for
// divergent toxin recovery; tighter thresholds give higher confidence
// on easy cases without sacrificing recall.
//
// Why this preset: when the GOI has a clean single-copy ortholog, you
// want strict family identity (no spurious paralog mis-assignment) and
// tighter classification bars (HIGH should mean HIGH).
//
// Use as a "sanity-check" baseline before running with relaxed presets.
//
// Use:   nextflow run main.nf -profile standard,preset_single_copy ...
//   or:  nextflow run main.nf -c conf/presets/single_copy_conserved.config ...

params {
    // Annotation-based family gate — single-copy genes usually have clean
    // cross-species annotation, so reject anything that doesn't match.
    strict_goi_family  = true
    expand_goi_similar = false

    // Tighter HIGH bar: 55% identity, 75% coverage minimum.
    classify_high_min_identity   = 55.0
    classify_medium_min_identity = 40.0
    classify_complete_min_qcov   = 0.75
}
