// SynVoy preset: tandem gene family
//
// For: tandemly arrayed paralog families where the GOI is one of many
// similar genes at the locus. Examples: LY6 cluster (~15 paralogs on
// human chr8), 3FTx snake-venom cluster, MRJP cluster in bees, defensin
// arrays, olfactory receptor clusters.
//
// Why this preset: the GOI's immediate neighbours are paralogs that share
// sequence similarity with it. Two consequences:
//   1. Paralogs make terrible synteny anchors — they match the GOI's
//      neighbourhood in any region containing a family member. Filter
//      them out aggressively with a tight `max_flanking_goi_similarity`.
//   2. Using paralogs as additional queries (`expand_goi_similar`) FLOODS
//      the per-target hits with paralog matches and drops the true
//      ortholog scaffold out of the adaptive region selection. Empirical:
//      LY6 ground-truth scaffold recall went from 8/9 (off) to 0/9 (on).
//
// Validated on: LY6/3FTx ground truth (tests/ground_truth_test/) —
// 7/9 confirmed scaffolds with the v4 fixes + this configuration.
//
// Use:   nextflow run main.nf -profile standard,preset_tandem_family ...
//   or:  nextflow run main.nf -c conf/presets/tandem_family.config ...

params {
    // Critical: do NOT amplify the query with GOI-similar neighbours.
    expand_goi_similar = false

    // Tighter k-mer filter — exclude any flanking candidate that shares
    // > 25% similarity with the GOI (default 35 is too permissive for
    // dense paralog clusters).
    max_flanking_goi_similarity = 25.0

    // Annotation-based family gate. Tokens auto-derived from query header
    // (UniProt GN=...); override with `--goi_family_tokens 'LY6E,LY6A,SLURP1,...'`.
    strict_goi_family = true

    // Slightly relaxed tandem identity — divergent paralogs (e.g. SLURP2 vs LY6E)
    // sit just below default MEDIUM bars but are biologically meaningful.
    classify_tandem_min_identity = 35.0
    classify_medium_min_identity = 30.0
}
